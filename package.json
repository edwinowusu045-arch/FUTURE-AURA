{
  "name": "future-aura",
  "private": true,
  "workspaces": [
    "next-app",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "build": "npm run build:frontend",
    "start": "npm run start:frontend",
    "build:frontend": "npm run build --workspace next-app",
    "start:frontend": "npm run start --workspace next-app",
    "build:backend": "npm run build --workspace server",
    "start:backend": "npm run start --workspace server",
    "lint": "npm run --workspace next-app lint && npm run --workspace server lint",
    "typecheck": "npm run --workspace next-app typecheck && npm run --workspace server typecheck",
    "test": "npm run --workspace next-app test",
    "db:migrate": "npm run --workspace server db:migrate",
    "db:seed": "npm run --workspace server db:seed"
  }
}
